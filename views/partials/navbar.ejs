<%
  var navItems = [
    { href: "/dashboard", icon: "bi-speedometer2", label: "Dashboard", key: "dashboard" },
    { href: "/equipment", icon: "bi-tools", label: "Equipment", key: "equipment" },
    { href: "/reservations", icon: "bi-calendar-check", label: "Reservations", key: "reservations" }
  ];
%>

<!-- Mobile topbar -->
<header class="topbar d-lg-none">
  <div class="topbar-inner">
    <button class="topbar-toggle" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas" aria-controls="sidebarOffcanvas" aria-label="Open navigation menu">
      <i class="bi bi-list"></i>
    </button>
    <a class="topbar-brand" href="/dashboard">
      <i class="bi bi-box-seam-fill"></i>EquipTrack
    </a>
    <a class="topbar-login" href="/login" aria-label="Login">
      <i class="bi bi-person-circle"></i>
    </a>
  </div>
</header>

<!-- Offcanvas sidebar (mobile) -->
<div class="offcanvas offcanvas-start sidebar-offcanvas" tabindex="-1" id="sidebarOffcanvas" aria-labelledby="sidebarOffcanvasLabel">
  <div class="offcanvas-header">
    <span class="sidebar-brand mb-0 pb-0" id="sidebarOffcanvasLabel">
      <i class="bi bi-box-seam-fill"></i>EquipTrack
    </span>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body d-flex flex-column">
    <div class="sidebar-account">
      <a href="/login" class="btn btn-outline-light-subtle <%= currentPage === 'login' ? 'active' : '' %>">Login</a>
      <a href="/register" class="btn btn-brand <%= currentPage === 'register' ? 'active' : '' %>">Register</a>
    </div>
    <div class="sidebar-section-label">Menu</div>
    <ul class="sidebar-nav">
      <% navItems.forEach(function(item) { %>
        <li>
          <a class="nav-link <%= currentPage === item.key ? 'active' : '' %>" href="<%= item.href %>">
            <i class="bi <%= item.icon %>"></i><%= item.label %>
          </a>
        </li>
      <% }); %>
    </ul>
    <div class="sidebar-footer-note">EquipTrack UI Preview &middot; Sample Data</div>
  </div>
</div>

<!-- Desktop sidebar -->
<aside class="sidebar d-none d-lg-flex flex-column">
  <a class="sidebar-brand" href="/dashboard">
    <i class="bi bi-box-seam-fill"></i>EquipTrack
  </a>

  <div class="sidebar-account">
    <a href="/login" class="btn btn-outline-light-subtle <%= currentPage === 'login' ? 'active' : '' %>">Login</a>
    <a href="/register" class="btn btn-brand <%= currentPage === 'register' ? 'active' : '' %>">Register</a>
  </div>

  <div class="sidebar-section-label">Menu</div>
  <ul class="sidebar-nav">
    <% navItems.forEach(function(item) { %>
      <li>
        <a class="nav-link <%= currentPage === item.key ? 'active' : '' %>" href="<%= item.href %>">
          <i class="bi <%= item.icon %>"></i><%= item.label %>
        </a>
      </li>
    <% }); %>
  </ul>

  <div class="sidebar-footer-note">EquipTrack UI Preview &middot; Sample Data</div>
</aside>

<div class="app-content">
